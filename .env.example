NODE_ENV=development

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=turismo

JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- JWT de clientes (sesión separada de la de admin, ver src/clientes-auth) ---
JWT_CLIENTE_SECRET=changeme-cliente
JWT_CLIENTE_REFRESH_SECRET=changeme-cliente-refresh
JWT_CLIENTE_ACCESS_EXPIRES=15m
JWT_CLIENTE_REFRESH_EXPIRES=7d

# --- Solo para "npm run seed" (crear el primer SUPER_ADMIN) ---
# Bórralos o cámbialos del .env real una vez que el seed se haya ejecutado.
SEED_ADMIN_EMAIL=admin@turismo.com
SEED_ADMIN_PASSWORD=12345678
SEED_ADMIN_NOMBRE=Admin

# --- Correo transaccional (SMTP) ---
# Si se dejan vacías, EmailService solo loguea el correo en vez de enviarlo.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tuagencia.com
ADMIN_NOTIFICATION_EMAIL=admin@tuagencia.com

# --- Asistente IA de correo (Gmail + Anthropic) ---
# Si se dejan vacías, el módulo queda desactivado automáticamente (no rompe
# el arranque de la app). Ver src/asistente-ia/README.md para el paso a
# paso de cómo obtener estas credenciales.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
ANTHROPIC_API_KEY=
